# Anon/publishable key — safe to expose to the browser, scoped by RLS.
NEXT_PUBLIC_SUPABASE_URL=https://sntcxllhlwnxxbrzcuxb.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_SfLAh8BkDnfKkQU8YP2ghQ_YhZDBCpB

# Optional: site URL for canonical links / OG tags. Vercel auto-populates this in production.
# NEXT_PUBLIC_SITE_URL=https://confair.com

# confair-api (Railway). Used server-side for two webhooks, both authenticated
# with the same Bearer secret:
#   1. "Apply for this job" — fires the Carerix push after capturing the
#      application in Supabase. If unset the application stays at
#      carerix_push_status='new' for the agency to push manually.
#   2. Contact form — forwards the lead to the HubSpot marketing/sales funnel
#      (see confair-api/docs/marketing-funnel.md). If unset the lead is still
#      captured in Supabase; only the CRM sync is skipped.
CONFAIR_API_URL=https://api.confair.com
WEBSITE_WEBHOOK_SECRET=replace-with-the-same-value-as-on-railway
