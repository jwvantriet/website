# confair-api (Railway). Used server-side by the "Apply for this job" handler
# to fire the Carerix push webhook after capturing the application in Supabase.
# Both must be set for the Carerix push to happen; if either is missing the
# application is still captured but stays at carerix_push_status='new' for the
# agency to push manually.
CONFAIR_API_URL=https://api.confair.com
WEBSITE_WEBHOOK_SECRET=replace-with-the-same-value-as-on-railway
